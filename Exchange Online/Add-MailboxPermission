foreach ($room in $rooms) {
    Write-Host "Granting FullAccess to $user on $room ..." -ForegroundColor Cyan
    Add-MailboxPermission -Identity $room -User $user -AccessRights FullAccess -AutoMapping:$true -ErrorAction Stop

    # Optional: also allow Send As (comment out if not needed)
    # Add-RecipientPermission -Identity $room -Trustee $user -AccessRights SendAs -ErrorAction Stop
}

Write-Host "Done. Propagation can take 5–30 minutes (auto-mapping can take longer)." -ForegroundColor Green
